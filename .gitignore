*.local
.extra
.env
.env.*

# Sensitive information
.ssh/
.aws/
.gnupg/
*.pem
*.key

# Editor backup files
*~
*.swp
*.swo
*.swn
.vimrc.local

# Compiled files
*.pyc
*.pyo
__pycache__/

# Logs
*.log

# Temporary files
tmp/
temp/
.cache/

# Node modules (if any scripts use them)
node_modules/

# Backup directories
.backup/
*.backup

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
